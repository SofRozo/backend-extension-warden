# ═══════════════════════════════════════════════════════════════════════════════
# Ext-Sandbox — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=extsandbox
DB_PASSWORD=extsandbox_secret
DB_NAME=extsandbox

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── Analysis Timeouts ────────────────────────────────────────────────────────
STATIC_TIMEOUT_MS=60000
DYNAMIC_TIMEOUT_MS=180000
MAX_CONCURRENT_WORKERS=10

# ─── Threat Intelligence APIs ─────────────────────────────────────────────────
# VirusTotal: https://www.virustotal.com/gui/my-apikey
# Free tier: 500 requests/day, 4 requests/minute
VIRUSTOTAL_API_KEY=caf2b17782c7d60f6e38103d4e3da6d3c76aa8010465667151108bb08c271791

# URLScan.io: https://urlscan.io/user/profile/ (optional — works without key)
URLSCAN_API_KEY=019de3a5-99f5-720b-9221-e57392ae32cf

# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

THREAT_INTEL_TIMEOUT_MS=10000
THREAT_INTEL_CACHE_TTL=86400

# ─── Honeypot / Storage State ─────────────────────────────────────────────────
# Path where encrypted storageState JSON files are stored (AES-256 per §11)
STORAGE_STATE_PATH=/data/honeypot/states

# AES-256 encryption key for storageState files (minimum 32 chars)
HONEYPOT_ENCRYPTION_KEY=change_me_to_a_strong_random_key_32chars

# ─── Docker Host Port ─────────────────────────────────────────────────────────
API_PORT=3000

# ─── Demo / Visual Worker ─────────────────────────────────────────────────────
# Two queues exist in Redis:
#   - "analysis"       (default)   → headless background; the dockerized worker
#   - "analysis-demo"              → visual demo with browser shown on host
#
# WORKER_QUEUE: which queue THIS worker process consumes (default: "analysis").
# Set to "analysis-demo" on a host-side worker that you want to run with
# DEMO_MODE=true so the browser is visible. Then POST /analyze with body
# { "extensionId": "...", "demo": true } and the job is routed to that worker.
#
# WORKER_QUEUE=analysis-demo
# DEMO_MODE=true
# DEMO_SLOW_MO=1200

# ─── Dynamic agent (Stagehand vs IntelligentNavigator) ─────────────────────────
# Both implementations drive Playwright with an LLM. Pick ONE per analysis run
# and re-analyze the same extension to compare them side by side. The active
# agent is logged at the start of each run and stored in
# report.navegacionDominios[].navigatorUsed so the frontend can show it.
#
#   ANALYSIS_USE_STAGEHAND=false  → IntelligentNavigator (default, casero,
#                                    cada paso loggeado con razón explícita)
#   ANALYSIS_USE_STAGEHAND=true   → Stagehand SDK (@browserbasehq/stagehand,
#                                    usa observe/act/extract internos)
#
# To watch decisions live, set DEMO_MODE=true (headed Chromium with slowMo)
# and tail the worker logs:
#   docker logs -f ext-sandbox-worker
# Each step prints lines like:
#   [Navigator|instagram.com|paso 2] LLM decidió: action=type ... | razón: ...
#
# ANALYSIS_USE_STAGEHAND=false
